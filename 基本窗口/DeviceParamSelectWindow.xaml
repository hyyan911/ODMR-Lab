<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Controls="clr-namespace:Controls;assembly=Controls" x:Class="ODMR_Lab.基本窗口.DeviceParamSelectWindow"
        mc:Ignorable="d"
        Title="DeviceFindWindow" Height="500" Width="600"  BorderThickness="2" WindowStyle="None" ResizeMode="NoResize" Background="#FF1F1F1F" BorderBrush="#FF0075DA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Label Background="#FF383838" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Content="     选择已连接设备" Foreground="#FFF6E8E8"/>
        <Controls:DecoratedButton Grid.Row="0" Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" x:Name="CloseBtn" Text="×" FontWeight="Thin" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray"/>
        <Grid Grid.Row="1" Margin="10" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Controls:ListViewer Name="ParamList" Grid.Column="1" Margin="4" ItemSelected="ParamList_ItemSelected" ItemBarSelectedColor="#FF358EDC" Background="#FF2E2E2E" ItemBarBackground="#FF2E2E2E">
                <Controls:ListViewer.DataTemplate>
                    <Controls:ViewerTemplate Descriptions="参数列表" DataType="String" Editable="False" DataDisplayWidth="*" />
                </Controls:ListViewer.DataTemplate>
                <Controls:ListViewer.HeaderLabelTemplate>
                    <Label HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="0" VerticalContentAlignment="Center" Foreground="White" FontSize="14" FontWeight="Bold" Background="#FF2E2E2E"/>
                </Controls:ListViewer.HeaderLabelTemplate>
                <Controls:ListViewer.UnEditableTextTemplate>
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Grid.Row="0" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="White" FontSize="10"/>
                </Controls:ListViewer.UnEditableTextTemplate>
            </Controls:ListViewer>
            <Controls:DecoratedButton Grid.Row="1" Click="Confirm" Grid.Column="0" Grid.ColumnSpan="2" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Text="确认" FontSize="16" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray"/>
        </Grid>
    </Grid>
</Window>
