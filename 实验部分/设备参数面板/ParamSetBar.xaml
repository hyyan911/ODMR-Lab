<Grid x:Class="ODMR_Lab.实验部分.设备参数面板.ParamSetBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:control="clr-namespace:Controls;assembly=Controls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="800">
    <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition/>
        <ColumnDefinition/>
        <ColumnDefinition Width="90"/>
        <ColumnDefinition Width="90"/>
        <ColumnDefinition Width="40"/>
    </Grid.ColumnDefinitions>
    <TextBox Grid.Column="0" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" Name="DeviceName" HorizontalContentAlignment="Center" IsHitTestVisible="True" VerticalContentAlignment="Center" FontSize="10" FontWeight="Normal" Text="11111111111111111" BorderThickness="0" TextWrapping="Wrap" BorderBrush="{x:Null}" IsReadOnly="True" Foreground="White" Background="Transparent" CaretBrush="White">
    </TextBox>
    <TextBox Grid.Column="1" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="10" FontWeight="Normal" Text="11111111111111111" TextWrapping="Wrap" BorderBrush="{x:Null}" Name="ParamName" IsReadOnly="True" Foreground="White" Background="Transparent" CaretBrush="White">
    </TextBox>
    <control:Chooser Name="BoolValue" Visibility="Visible" Margin="4" Grid.Column="2" Width="30" Height="15" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" Background="Transparent"/>
    <TextBox Name="StringValue" Visibility="Visible" Margin="4" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="10" FontWeight="Normal" Text="11111111111111111" TextWrapping="Wrap" BorderBrush="{x:Null}" IsReadOnly="True" Foreground="White" Background="Transparent" CaretBrush="White">
    </TextBox>
    <control:ComboBox Name="EnumValue" FontSize="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Visible" TextAreaRatio="0.9" ImagePlace="Right" IconSource="/图片资源/downArrow.png" IconMargin="4" Grid.Column="2" Margin="4"  Background="#FF383838" Foreground="#FFFAFAFA" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="#FFFAFAFA" PressedForeground="#FFFAFAFA"/>
    <control:DecoratedButton Grid.Column="3" Visibility="Visible" Margin="6" Click="ReadCommand" Text="读取" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="#FFFAFAFA" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="#FFFAFAFA" PressedForeground="#FFFAFAFA"/>
    <control:DecoratedButton Grid.Column="4" Visibility="Visible" Margin="6" Click="SetCommand" Text="设置" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="#FFFAFAFA" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="#FFFAFAFA" PressedForeground="#FFFAFAFA"/>
    <Label Name="Warning" Cursor="Hand" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" Grid.Column="5" Padding="10">
        <Label.Content>
            <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/warning.png"/>
        </Label.Content>
    </Label>
</Grid>
