<odmr_lab:ExpPageBase  xmlns:odmr_lab="clr-namespace:ODMR_Lab" x:Class="ODMR_Lab.自定义算法.DisplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:chart="clr-namespace:Controls.Charts;assembly=Controls" xmlns:control="clr-namespace:Controls;assembly=Controls"
      mc:Ignorable="d" 
      xmlns:image="clr-namespace:ODMR_Lab.基本控件"
      d:DesignHeight="600" d:DesignWidth="800" Margin="10"
      >
    <Grid.RowDefinitions>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200"/>
        <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <control:ExpandableBar BorderThickness="0.5" Margin="3" BarPlacement="Left" IsExpand="True" ExpandedText="&lt;&lt;" FrinkedText="算法列表" FrinkedLength="30" Grid.Column="0" Grid.Row="0" BorderBrush="#FF707070">
        <control:ExpandableBar.ButtonTemplate>
            <control:DecoratedButton HorizontalAlignment="Stretch" TextAreaRatio="1" FontSize="12" Background="Transparent" Foreground="LightGray" MoveInColor="#FF333333" PressedColor="#FF333333" MoveInForeground="LightGray" PressedForeground="LightGray" VerticalAlignment="Stretch"/>
        </control:ExpandableBar.ButtonTemplate>
        <control:ExpandableBar.ContentPanel>
            <control:ListViewer Name="AlgorithmNames" Width="150" ItemSelected="AlgorithmNames_ItemSelected" ItemContextMenuSelected="AlgorithmNames_ItemContextMenuSelected" ItemBarSelectedColor="#FF5BB3ED" ItemBarBackground="#FF2E2E2E">
                <control:ListViewer.DataTemplate>
                    <control:ViewerTemplate Descriptions="算法名称" DataType="String" Editable="False" DataDisplayWidth="*"/>
                </control:ListViewer.DataTemplate>
                <control:ListViewer.TextBoxTemplate>
                    <TextBox HorizontalAlignment="Stretch" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="11" Background="Transparent" CaretBrush="White"/>
                </control:ListViewer.TextBoxTemplate>
                <control:ListViewer.HeaderLabelTemplate>
                    <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White" FontSize="12"/>
                </control:ListViewer.HeaderLabelTemplate>
                <control:ListViewer.ItemContextMenu>
                    <control:ContextMenu>
                        <control:ContextMenu.Items>
                            <control:DecoratedButton Text="显示算法描述" FontSize="12" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                        </control:ContextMenu.Items>
                    </control:ContextMenu>
                </control:ListViewer.ItemContextMenu>
            </control:ListViewer>
        </control:ExpandableBar.ContentPanel>
    </control:ExpandableBar>
    <Grid Grid.Column="1" Grid.Row="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Label HorizontalContentAlignment="Center" Grid.Row="0" Grid.ColumnSpan="2" Content="输入参数" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White" FontSize="12"/>
        <Label HorizontalContentAlignment="Center" Grid.Row="2" Grid.ColumnSpan="2" Content="输出参数" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White" FontSize="12"/>
        <control:DecoratedButton Name="CalcBtn" Visibility="Hidden" Margin="5" Click="Calculate" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" IconMargin="4" TextAreaRatio="1" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White" Canvas.Top="343" Text="计算" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <control:DecoratedButton Name="GraphBtn" Visibility="Hidden" Margin="5" Click="ShowGraph" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" IconMargin="4" TextAreaRatio="1" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White" Canvas.Top="343" Text="输出图表预览" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <TextBlock Visibility="Hidden" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" TextAlignment="Center" TextWrapping="Wrap"/>
        <control:AutoScrollViewer Grid.Row="1" Name="input">
            <control:AutoScrollViewer.Content>
                <WrapPanel Name="InputParams"  Width="{Binding ElementName= input, Path=ActualWidth}">
                </WrapPanel>
            </control:AutoScrollViewer.Content>
        </control:AutoScrollViewer>
        <control:AutoScrollViewer Grid.Row="3" Name="output">
            <control:AutoScrollViewer.Content>
                <WrapPanel Name="OutputParams" Width="{Binding ElementName=output, Path=ActualWidth}">
                </WrapPanel>
            </control:AutoScrollViewer.Content>
        </control:AutoScrollViewer>
    </Grid>
</odmr_lab:ExpPageBase>
