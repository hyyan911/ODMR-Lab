<Window x:Class="ODMR_Lab.实验部分.序列编辑器.GroupChannelEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ODMR_Lab.实验部分.序列编辑器" xmlns:control="clr-namespace:Controls;assembly=Controls"
        mc:Ignorable="d"
        Title="通道名设置" Height="382" Width="423" BorderThickness="2" ResizeMode="NoResize" WindowStyle="None" Background="#FF1F1F1F" BorderBrush="#FF0075DA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Label Name="title" Grid.Row="0" Content="       请确认序列组的通道名" IsHitTestVisible="False" Grid.ColumnSpan="3" FontWeight="ExtraBold" Background="#FF383838" Foreground="#FFFAFAFA"/>
        <control:DecoratedButton Name='CloseBtn' Grid.Column="3" IconMargin="7" TextAreaRatio="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontWeight="Thin" FontSize="20" Canvas.Left="1126" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/close.png"/>
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Label Content="脉冲组合名:" Foreground="White" HorizontalContentAlignment="Center"/>
                <TextBox x:Name="GroupName" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0" Text=""  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="11" BorderThickness="0" Background="#FF2E2E2E" BorderBrush="{x:Null}" Foreground="White"/>
            </Grid>
            <control:ListViewer x:Name="ChannelPanel" Grid.Row="1" HeaderHeight="30" ItemHeight="30" MinItemWidth="150" ItemBarSelectedColor="#FF0084C8" ItemBarBackground="{x:Null}" Background="#FF2E2E2E">
                <control:ListViewer.DataTemplate>
                    <control:ViewerTemplate Descriptions="通道序号" DataType="String" Editable="False" DataDisplayWidth="*" />
                    <control:ViewerTemplate Descriptions="名称" DataType="String" Editable="True" DataDisplayWidth="2*" />
                </control:ListViewer.DataTemplate>
                <control:ListViewer.HeaderLabelTemplate>
                    <Label HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="0" VerticalContentAlignment="Center" Foreground="White" FontSize="10" FontWeight="Bold" Background="#FF1F1F1F"/>
                </control:ListViewer.HeaderLabelTemplate>
                <control:ListViewer.UnEditableTextTemplate>
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Grid.Row="0" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="White" FontSize="10"/>
                </control:ListViewer.UnEditableTextTemplate>
                <control:ListViewer.EditableBoxTemplate>
                    <TextBox HorizontalContentAlignment="Center" CaretBrush="White"  Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Background="#FF4D4D4D"/>
                </control:ListViewer.EditableBoxTemplate>
                <control:ListViewer.ItemContextMenu>
                    <control:ContextMenu>
                        <control:ContextMenu.Items>
                            <control:DecoratedButton Text="删除" FontSize="12" Background="#FF4D4D4D" MoveInColor="#FF358EFF" PressedColor="#FF0082DA" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                        </control:ContextMenu.Items>
                    </control:ContextMenu>
                </control:ListViewer.ItemContextMenu>
                <control:ListViewer.EditableBooleanTemplate>
                    <control:Chooser Width="30" Height="15"/>
                </control:ListViewer.EditableBooleanTemplate>
            </control:ListViewer>
            <control:DecoratedButton Click="Confirm" Grid.Row="2" Margin="5" Text="确定" FontSize="12" Grid.Column="0" TextAreaRatio="1" IconMargin="4" FontWeight="Thin"  Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
        </Grid>
    </Grid>
</Window>
