<local:ChannelSequenceControlBase x:Class="ODMR_Lab.实验部分.序列编辑器.子控件.MultiChannelSequenceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ODMR_Lab.实验部分.序列编辑器.子控件" xmlns:controls="clr-namespace:Controls;assembly=Controls"
                                       mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="500" HorizontalAlignment="Stretch" Background="Transparent" Height="40">
    <Grid Name="SingleSegPanel" Visibility="Hidden">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <controls:DecoratedButton ToolTip="信号名称" Name="Sequencename" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="0" Click="SelectSequenceName" Grid.ColumnSpan="1" FontSize="10" TextAreaRatio="1" IconMargin="4" FontWeight="Thin"  Background="Transparent" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
        <Label Name="WaveState" ToolTip="信号值(灰色为低电平，蓝色为高电平)" Cursor="Hand" MouseLeftButtonDown="SetWaveState" Grid.Column="2" Width="10" Height="10" Background="#FF00DC45"/>
        <Label Name="WaveLength" ToolTip="信号长度(ns)" Grid.Column="1" FontSize="11" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White"/>
        <controls:Chooser Name="IsTrigger" ToolTip="是否是Trigger信号" Width="30" Height="15" Grid.Column="3" IsSelected="False" Selected="TriggerSelected" UnSelected="TriggerSelected"/>
    </Grid>
    <Grid Name="MultiSegPanel" Visibility="Hidden">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <controls:DecoratedButton ToolTip="信号组名称" Name="SequenceGroupname" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="0" Click="SelectSequenceGroupName" Grid.ColumnSpan="1" FontSize="10" TextAreaRatio="1" IconMargin="4" FontWeight="Thin"  Background="Transparent" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
        <controls:DecoratedButton ToolTip="信号组通道" Name="GroupChannelName" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="1" Click="SelectSequenceGroupChannel" Grid.ColumnSpan="1" FontSize="10" TextAreaRatio="1" IconMargin="4" FontWeight="Thin"  Background="Transparent" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
        <controls:DecoratedButton Grid.Column="4" Margin="10" HorizontalAlignment="Right" Height="15" Width="40" CornerRadius="5" Text="脉冲组合" FontSize="7" FontWeight="Bold" VerticalAlignment="Bottom" Grid.ColumnSpan="1" TextAreaRatio="1" IconMargin="4"  Background="#FFFF9D00" Foreground="White" MoveInColor="#FFFF9D00" PressedColor="#FFFF9D00" MoveInForeground="White" PressedForeground="White"/>
    </Grid>
</local:ChannelSequenceControlBase>
