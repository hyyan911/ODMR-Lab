<Popup x:Class="ODMR_Lab.实验部分.序列编辑器.子控件.GroupRelationSelectionPop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ODMR_Lab.实验部分.序列编辑器.子控件"
             xmlns:control="clr-namespace:Controls;assembly=Controls"
             mc:Ignorable="d" Closed="Popup_Closed" AllowsTransparency="True"
             >
    <Grid Width="300" Height="300">
        <control:ListViewer Name="panel" ItemBarBackground="{x:Null}" Background="#FF2E2E2E" BorderThickness="1" BorderBrush="#FF4D4D4D" >
            <control:ListViewer.DataTemplate>
                <control:ViewerTemplate Descriptions="通道序号" DataType="String" Editable="False" DataDisplayWidth="*" />
                <control:ViewerTemplate Descriptions="脉冲组合通道名" DataType="List" Editable="True" DataDisplayWidth="*" />
            </control:ListViewer.DataTemplate>
            <control:ListViewer.HeaderLabelTemplate>
                <Label HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="0" VerticalContentAlignment="Center" Foreground="White" FontSize="10" FontWeight="Bold" Background="#FF1F1F1F"/>
            </control:ListViewer.HeaderLabelTemplate>
            <control:ListViewer.UnEditableTextTemplate>
                <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Grid.Row="0" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="White" FontSize="10"/>
            </control:ListViewer.UnEditableTextTemplate>
            <control:ListViewer.EnumComboBoxTemplate>
                <control:ComboBox FontSize="10" Grid.Column="0" TextAreaRatio="1" Margin="4" IconMargin="4" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White">
                    <control:ComboBox.TemplateButton>
                        <control:DecoratedButton FontSize="10" Grid.Column="0" TextAreaRatio="1" IconMargin="4" Background="#FF383838" Foreground="White" MoveInColor="#FF359BFF" PressedColor="#FF0076D0" MoveInForeground="White" PressedForeground="White"/>
                    </control:ComboBox.TemplateButton>
                </control:ComboBox>
            </control:ListViewer.EnumComboBoxTemplate>
        </control:ListViewer>
    </Grid>
</Popup>
