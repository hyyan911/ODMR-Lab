<Grid x:Class="ODMR_Lab.实验部分.设备参数监测.DeviceNumricBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ODMR_Lab.实验部分.设备参数监测"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="400" Height="50">
    <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition/>
        <ColumnDefinition Width="2*"/>
    </Grid.ColumnDefinitions>
    <TextBox Grid.Column="0" Name="DeviceName" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="13" FontWeight="Normal" Text="11111111111111111" BorderThickness="0" TextWrapping="Wrap" HorizontalScrollBarVisibility="Auto" BorderBrush="{x:Null}" IsReadOnly="True" Foreground="White" Background="{x:Null}" CaretBrush="White">
    </TextBox>
    <TextBox Grid.Column="1" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="13" FontWeight="Normal" Text="11111111111111111" TextWrapping="Wrap" BorderBrush="{x:Null}" Name="ParamName" IsReadOnly="True" Foreground="White" Background="{x:Null}" CaretBrush="White">
    </TextBox>
    <TextBox Grid.Column="2" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="15" FontWeight="Bold" Text="11111111111111111" TextWrapping="Wrap" BorderBrush="{x:Null}" Name="ParamValue" IsReadOnly="True" Foreground="White" Background="{x:Null}" CaretBrush="White">
    </TextBox>
</Grid>
