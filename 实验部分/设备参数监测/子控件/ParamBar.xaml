<Grid x:Class="ODMR_Lab.实验部分.设备参数监测.ParamBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ODMR_Lab.实验部分.设备参数监测"
             mc:Ignorable="d" 
             d:DesignWidth="400" Background="Transparent" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
    <Grid.RowDefinitions>
        <RowDefinition Height="50"/>
    </Grid.RowDefinitions>
    <Grid Grid.ColumnSpan="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="1" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" Name="DeviceName" HorizontalContentAlignment="Center" IsHitTestVisible="True" VerticalContentAlignment="Center" FontSize="10" FontWeight="Normal" Text="11111111111111111" BorderThickness="0" TextWrapping="Wrap" BorderBrush="{x:Null}" IsReadOnly="True" Foreground="White" Background="Transparent" CaretBrush="White">
        </TextBox>
        <TextBox Grid.Column="2" PreviewMouseLeftButtonDown="Grid_MouseLeftButtonDown" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="10" FontWeight="Normal" Text="11111111111111111" TextWrapping="Wrap" BorderBrush="{x:Null}" Name="ParamName" IsReadOnly="True" Foreground="White" Background="Transparent" CaretBrush="White">
        </TextBox>

        <Label Name="ColorLabel" HorizontalAlignment="Left" Width="20" VerticalAlignment="Stretch" Margin="0" Grid.Column="0" Cursor="Hand" Background="#FF31EDAF" MouseLeftButtonUp="ColorLabel_MouseLeftButtonDown"/>
        <Label Name="DataVisible" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible" Background="Transparent" MouseLeftButtonDown="DataVisible_MouseLeftButtonDown" Cursor="Hand" Grid.Column="4" Padding="17">
            <Label.Content>
                <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/visible.png"/>
            </Label.Content>
        </Label>
        <Label Name="Warning" Cursor="Hand" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent" Grid.Column="3" Padding="17">
            <Label.Content>
                <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/warning.png"/>
            </Label.Content>
        </Label>
        <Label Name="DataInVisible" HorizontalAlignment="Center" Visibility="Hidden" Background="Transparent" MouseLeftButtonDown="DataInVisible_MouseLeftButtonDown" Cursor="Hand" Grid.Column="4" Padding="17" Height="50" VerticalAlignment="Center">
            <Label.Content>
                <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/invisible.png"/>
            </Label.Content>
        </Label>
        <Label Name="Sample" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible" Background="Transparent" MouseLeftButtonDown="Sample_MouseLeftButtonDown" Cursor="Hand" Grid.Column="5" Padding="17">
            <Label.Content>
                <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/play.png"/>
            </Label.Content>
        </Label>
        <Label Name="StopSample" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" Background="Transparent" MouseLeftButtonDown="StopSample_MouseLeftButtonDown" Cursor="Hand" Grid.Column="5" Padding="10" Height="50">
            <Label.Content>
                <Image HorizontalAlignment="Stretch" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Stretch" Source="/图片资源/stop.png"/>
            </Label.Content>
        </Label>
    </Grid>
</Grid>
