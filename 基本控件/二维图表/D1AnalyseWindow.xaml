<Window x:Class="ODMR_Lab.基本控件.D1AnalyseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ODMR_Lab.基本窗口" xmlns:control="clr-namespace:Controls;assembly=Controls" xmlns:chart="clr-namespace:Controls.Charts;assembly=Controls"
        mc:Ignorable="d"
        Title="参数设置" Height="300" Width="600" WindowChrome.IsHitTestVisibleInChrome="False" BorderThickness="2" ResizeMode="NoResize" WindowStyle="None" Background="#FF1F1F1F" BorderBrush="#FF0075DA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Label Name="title" Grid.Row="0" Content="       一维分析" IsHitTestVisible="False" Grid.ColumnSpan="2" FontWeight="ExtraBold" Background="#FF383838" Foreground="#FFFAFAFA"/>
        <control:DecoratedButton Name="CloseBtn" Grid.Column="3" IconMargin="7" TextAreaRatio="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontWeight="Thin" FontSize="20" Canvas.Left="1026" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/close.png"/>
        <control:DecoratedButton Name="MinBtn" Grid.Column="2" IconMargin="7" TextAreaRatio="0" Grid.Row="0" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IconSource="/图片资源/minimize.png" />
        <control:DecoratedButton Name="PinBtn" Grid.Column="1" IconMargin="7" TextAreaRatio="0" Grid.Row="0" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF7C7C7C" MoveInForeground="LightGray" PressedForeground="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IconSource="/图片资源/pin.png" />
        <Grid Name="ContentPanel" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Foreground="White" FontSize="12" Visibility="Visible" Grid.Row="0" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center" Text="X轴结果"/>
            <TextBlock Foreground="White" FontSize="12" Visibility="Visible" Grid.Row="1" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center" Text="Y轴结果"/>
            <chart:ChartControl Name="chartX" SnapsToDevicePixels="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="0" Grid.Column="1" LegendFontsize="13" LegendHAlignment="Right" LegendVAlignment="Top" MajorGridThickness="1" GridLineNumber="8" AxisFontsize="16" AxisMajorTickColor="Transparent" AxisMinorTickColor="Transparent" PanY="False" MinorGridThickness="0" Zoom="True" ChartBackground="#FF1F1F1F" DataAreaBackground="#FF1F1F1F" MajorGridColor="#FF888A85" MinorGridColor="#FF7C7C7C" EdgeColor="Transparent" LegendBackground="#FF4D4D4D" LegendForeground="#FFFAFAFA"/>
            <Grid Grid.Row="0" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <control:DecoratedButton Click="SnapX" Grid.Row="0" Grid.Column="0" Margin="5" TextAreaRatio="0" IconMargin="4" ToolTip="复制截图到剪切板" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/snap.png" Grid.RowSpan="2"/>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <control:DecoratedButton Click="SnapY" Grid.Row="0" Grid.Column="0" Margin="5" TextAreaRatio="0" IconMargin="4" ToolTip="复制截图到剪切板" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/snap.png" Grid.RowSpan="2"/>
            </Grid>
            <chart:ChartControl Name="chartY" SnapsToDevicePixels="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Row="1" Grid.Column="1" LegendFontsize="13" LegendHAlignment="Right" LegendVAlignment="Top" MajorGridThickness="1" GridLineNumber="8" AxisFontsize="16" AxisMajorTickColor="Transparent" AxisMinorTickColor="Transparent" PanY="False" MinorGridThickness="0" Zoom="True" ChartBackground="#FF1F1F1F" DataAreaBackground="#FF1F1F1F" MajorGridColor="#FF888A85" MinorGridColor="#FF7C7C7C" EdgeColor="Transparent" LegendBackground="#FF4D4D4D" LegendForeground="#FFFAFAFA"/>
            <control:AutoScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4">
                <control:AutoScrollViewer.Content>
                    <WrapPanel Orientation="Horizontal">
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White" FontSize="10" Margin="2" Content="曲线类型" />
                        <control:ComboBox Name="PlotStyle" FontSize="10" DefaultSelectIndex="0" SelectionChanged="ApplyLineStyle" Width="70" Height="30" Margin="5" PanelWidth="60" TextAreaRatio="0.8" IconMargin="2" ImagePlace="Right" Background="#FF383838" MoveInColor="#FF4D4D4D" PressedColor="#FF2E2E2E" IconSource="/图片资源/downArrow.png" Foreground="White" MoveInForeground="White" PressedForeground="White">
                            <control:ComboBox.Items>
                                <control:DecoratedButton Height="40" Text="线状图" Background="#FF383838" MoveInColor="#FF4D4D4D" PressedColor="#FF007AD9" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                                <control:DecoratedButton Height="40" Text="点状图" Background="#FF383838" MoveInColor="#FF4D4D4D" PressedColor="#FF007AD9" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                                <control:DecoratedButton Height="40" Text="点线图" Background="#FF383838" MoveInColor="#FF4D4D4D" PressedColor="#FF007AD9" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                            </control:ComboBox.Items>
                        </control:ComboBox>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White" FontSize="10" Margin="2" Content="线宽:"/>
                        <TextBox x:Name="LineWidth" Text="1" LostFocus="ApplyLineStyle" KeyDown="ApplyLineStyleKey" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="10" BorderThickness="0" Background="#FF424242" BorderBrush="{x:Null}" Foreground="White" Height="30" Width="60"/>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White" FontSize="10" Margin="2" Content="平滑曲线:"/>
                        <control:Chooser Name="IsSmooth" Width="30" Selected="ApplyLineStyle" UnSelected="ApplyLineStyle" Height="15" IsSelected="False" Margin="10"/>
                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="White" FontSize="10" Margin="2" Content="点尺寸:"/>
                        <TextBox x:Name="PointSize" Text="10" KeyDown="ApplyLineStyleKey" LostFocus="ApplyLineStyle" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="10" BorderThickness="0" Background="#FF424242" BorderBrush="{x:Null}" Foreground="White" Height="30" Width="60"/>
                        <Label  Content="当前光标数:" FontSize="12" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5"/>
                        <Label  Name="CursorCount" FontSize="12" Foreground="White" Width="30" Content="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5"/>
                        <control:DecoratedButton Margin="7" Width="60" Click="AddCursor" Grid.Row="2" Grid.Column="0" TextAreaRatio="1" ToolTip="新建光标" Text="新建光标" FontWeight="Thin" FontSize="12" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                        <control:DecoratedButton Margin="7" Width="80" Click="BringCursorToCenter" Grid.Row="2" Grid.Column="0" TextAreaRatio="1" ToolTip="设置光标到中心位置" Text="设置光标到中心位置" FontWeight="Thin" FontSize="12" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                    </WrapPanel>
                </control:AutoScrollViewer.Content>
            </control:AutoScrollViewer>
            <control:DecoratedButton Grid.Row="0" Grid.Column="3" Grid.RowSpan="2" Grid.ColumnSpan="1" Margin="5" VerticalAlignment="Stretch" Text="刷新绘图" Click="UpdatePlot"  FontSize="13"  Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray"/>
        </Grid>
    </Grid>
</Window>
