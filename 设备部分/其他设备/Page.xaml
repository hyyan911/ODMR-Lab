<odmr_lab:DevicePageBase  xmlns:odmr_lab="clr-namespace:ODMR_Lab.设备部分" x:Class="ODMR_Lab.设备部分.其他设备.DevicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:chart="clr-namespace:Controls.Charts;assembly=Controls" xmlns:control="clr-namespace:Controls;assembly=Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      >
    <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="40"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="400"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <control:ComboBox Name="DeviceTypeBox" DefaultSelectIndex="0" SelectionChanged="DeviceTypeBox_SelectionChanged" Margin="5" MaxPanelHeight="600" FontSize="11" Background="#FF2E2E2E" TextAreaRatio="0.9" IconMargin="4" ImagePlace="Right" MoveInColor="#FF4D4D4D" PressedColor="#FF424242" IconSource="/图片资源/downArrow.png" Foreground="White" MoveInForeground="White" PressedForeground="White">
    </control:ComboBox>
    <control:ListViewer Name="DeviceList" Grid.Row="1" HeaderHeight="0" Grid.ColumnSpan="1" ItemSelected="DeviceList_ItemSelected" ItemContextMenuSelected="CloseDevice" Grid.RowSpan="1" Margin="10" ItemBarSelectedColor="#FF00ACFF" ItemBarBackground="#FF4D4D4D" Background="#FF2E2E2E">
        <control:ListViewer.ItemContextMenu>
            <control:ContextMenu>
                <control:ContextMenu.Items>
                    <control:DecoratedButton Text="关闭设备" FontSize="12" Background="#FF4D4D4D" MoveInColor="#FF358EFF" PressedColor="#FF0082DA" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                    <control:DecoratedButton Text="参数设置" FontSize="12" Background="#FF4D4D4D" MoveInColor="#FF358EFF" PressedColor="#FF0082DA" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                </control:ContextMenu.Items>
            </control:ContextMenu>
        </control:ListViewer.ItemContextMenu>
        <control:ListViewer.DataTemplate>
            <control:ViewerTemplate Descriptions="已连接设备" DataDisplayWidth="*" DataType="String" Editable="False"/>
        </control:ListViewer.DataTemplate>
        <control:ListViewer.HeaderLabelTemplate>
            <Label Foreground="White" Background="#FF1A1A1A" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" FontSize="14"/>
        </control:ListViewer.HeaderLabelTemplate>
        <control:ListViewer.TextBoxTemplate>
            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="11" Background="Transparent" CaretBrush="White"/>
        </control:ListViewer.TextBoxTemplate>
        <control:ListViewer.EditableBooleanTemplate>
            <control:Chooser Width="40" Height="20"/>
        </control:ListViewer.EditableBooleanTemplate>
    </control:ListViewer>
    <control:ListViewer Name="DeviceChannelList" Grid.Column="1" Grid.RowSpan="4" Margin="5" ItemContextMenuSelected="ChannelContextMenuEvent" ItemBarBackground="#FF4D4D4D" Background="#FF2E2E2E" ItemBarSelectedColor="#FF00ACFF">
        <control:ListViewer.ItemContextMenu>
            <control:ContextMenu>
                <control:ContextMenu.Items>
                    <control:DecoratedButton Text="参数设置" FontSize="12" Background="#FF4D4D4D" MoveInColor="#FF358EFF" PressedColor="#FF0082DA" Foreground="White" MoveInForeground="White" PressedForeground="White"/>
                </control:ContextMenu.Items>
            </control:ContextMenu>
        </control:ListViewer.ItemContextMenu>
        <control:ListViewer.DataTemplate>
            <control:ViewerTemplate Descriptions="通道列表" DataDisplayWidth="*" DataType="String" Editable="False"/>
        </control:ListViewer.DataTemplate>
        <control:ListViewer.HeaderLabelTemplate>
            <Label Grid.Row="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Grid.Column="1" FontSize="14" FontWeight="Bold" Foreground="#FFFAFAFA" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FF1A1A1A"/>
        </control:ListViewer.HeaderLabelTemplate>
        <control:ListViewer.TextBoxTemplate>
            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="11" Background="Transparent" CaretBrush="White"/>
        </control:ListViewer.TextBoxTemplate>
        <control:ListViewer.EditableBooleanTemplate>
            <control:Chooser Width="40" Height="20"/>
        </control:ListViewer.EditableBooleanTemplate>
    </control:ListViewer>
    <control:DecoratedButton Grid.Row="2" Grid.ColumnSpan="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5" Click="NewConnect" Text="新建连接" FontWeight="Thin" FontSize="14" Background="#FF383838" Foreground="#FFFAFAFA" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="#FFFAFAFA" PressedForeground="#FFFAFAFA"/>
    <Grid Grid.Row="1" Grid.Column="2">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
    </Grid>
    <Grid Grid.Row="0" Grid.Column="3" Grid.RowSpan="3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <control:DecoratedButton Visibility="Collapsed" Background="#FF177200" Text="111" FontWeight="Bold" Height="50" Width="195" CornerRadius="10" MoveInColor="#FF00A301" PressedColor="#FF007E01" Foreground="#FFFAECFA" MoveInForeground="#FFFAECFA" PressedForeground="#FFFAECFA"/>
        <control:DecoratedButton Visibility="Collapsed" Background="#FFC88E00" Text="111" FontWeight="Bold" Height="50" Width="195" CornerRadius="10" MoveInColor="#FFE5AB1F" PressedColor="#FFC08800" Foreground="#FFFAECFA" MoveInForeground="#FFFAECFA" PressedForeground="#FFFAECFA"/>
    </Grid>
</odmr_lab:DevicePageBase>
