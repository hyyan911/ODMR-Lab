<local:ProcesspageBase  xmlns:local="clr-namespace:ODMR_Lab.数据处理.数据处理窗口.数据处理方法界面" x:Class="ODMR_Lab.数据处理.数据处理窗口.数据处理方法界面.Python脚本映射计算.ProcessPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:control="clr-namespace:Controls;assembly=Controls" xmlns:control1="clr-namespace:Controls.Algebra;assembly=Controls"
      mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="170"/>
        </Grid.RowDefinitions>
        <Grid Name="PythonPanel" Grid.Row="0" Grid.ColumnSpan="3" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="1" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBox IsReadOnly="True" BorderThickness="0" BorderBrush="Transparent" Name="PythonFileDir" Text="" Grid.Row="1" Margin="3" Grid.ColumnSpan="1" FontSize="10" IsHitTestVisible="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FF383838" Foreground="#FFFAFAFA" CaretBrush="White"/>
                    <control:DecoratedButton Grid.Column="2" TextAreaRatio="0" Grid.Row="1" Click="SelectPythonFilePath" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/directory.png" IconMargin="5" Margin="3"/>
                </Grid>
                <Label Grid.Row="0" Content="文件路径" FontSize="12" Margin="2" Grid.ColumnSpan="3" IsHitTestVisible="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FF1A1A1A" Foreground="#FFFAFAFA"/>
                <Label Content="函数名" Grid.Row="2" Margin="5" Grid.ColumnSpan="1" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{x:Null}" Foreground="#FFFAFAFA"/>
                <control:ComboBox Name="PyhtonFunc" FontSize="11" Margin="2" IconMargin="5" TextAreaRatio="0.9" ImagePlace="Right" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Background="#FF424242" PressedColor="#FF3E3E3E" PressedForeground="White" MoveInForeground="White" Foreground="White" MoveInColor="#FF4D4D4D" IconSource="/图片资源/downArrow.png"/>
                <Label Content="超时时间(ms)" Grid.Row="3" Margin="2" Grid.ColumnSpan="1" IsHitTestVisible="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{x:Null}" Foreground="#FFFAFAFA"/>
                <TextBox Name="PythonTimeout" Grid.Column="1" Grid.ColumnSpan="2" Margin="2" Grid.Row="3" BorderThickness="0" FontSize="11" Text="1000" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="#FF383838" Foreground="#FFF0F0F0" CaretBrush="White"/>
            </Grid>
            <control:ListViewer Name="InputParam" HeaderHeight="30" Grid.Column="1" ItemBarBackground="#FF1A1A1A" ItemBarSelectedColor="#FF4CA1FF">
                <control:ListViewer.HeaderLabelTemplate>
                    <Label IsHitTestVisible="False" FontSize="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{x:Null}" Foreground="#FFFAFAFA"/>
                </control:ListViewer.HeaderLabelTemplate>
                <control:ListViewer.DataTemplate>
                    <control:ViewerTemplate Descriptions="参数名" DataType="String" Editable="False" DataDisplayWidth="*"/>
                    <control:ViewerTemplate Descriptions="数据变量名" DataType="String" Editable="True" DataDisplayWidth="*"/>
                </control:ListViewer.DataTemplate>
                <control:ListViewer.TextBoxTemplate>
                    <TextBox HorizontalAlignment="Stretch" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="11" Background="Transparent" CaretBrush="White"/>
                </control:ListViewer.TextBoxTemplate>
            </control:ListViewer>
        </Grid>
        <TextBlock Grid.Row="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"><Run Text="此功能用于使用Python脚本计算映射值，Python脚本需要包含用于计算的函数，函数格式如下："/><LineBreak/><Run/><LineBreak/><Run Text="1.函数输出必须为单值"/><Run Text="，返回一个"/><Run Language="zh-cn" Text="一维"/><Run Text="列表"/><Run Text="。"/><LineBreak/><Run/><LineBreak/><Run Text="2"/><Run Text=".传入脚本的"/><Run Text="数据"/><Run Text="为列表类型。"/><Run Text="个数与顺序与函数的输入参数数量保持一致"/><LineBreak/><Run/><LineBreak/><Run Text="注意：当前仅支持一维数据的计算"/></TextBlock>
    </Grid>
</local:ProcesspageBase>