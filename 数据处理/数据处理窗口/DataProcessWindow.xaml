<Window x:Class="ODMR_Lab.数据处理.DataProcessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ODMR_Lab.数据处理" xmlns:control="clr-namespace:Controls;assembly=Controls" xmlns:基本控件="clr-namespace:ODMR_Lab.基本控件" xmlns:control1="clr-namespace:Controls.Algebra;assembly=Controls" xmlns:cal="clr-namespace:ODMR_Lab.数据处理.数据处理窗口.数据处理方法界面.简单映射计算"
        mc:Ignorable="d"
        Title="数据处理窗口" Height="500" Width="1000" WindowChrome.IsHitTestVisibleInChrome="False" BorderThickness="2" ResizeMode="NoResize" WindowStyle="None" Background="#FF1F1F1F" BorderBrush="#FF0075DA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Content="       数据处理窗口" IsHitTestVisible="False" Grid.ColumnSpan="1" FontWeight="ExtraBold" Background="#FF383838" Foreground="#FFFAFAFA"/>
        <control:DecoratedButton Name="PinBtn" Grid.Column="1" IconMargin="7" TextAreaRatio="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontWeight="Thin" FontSize="20" Canvas.Left="1126" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/pin.png"/>
        <control:DecoratedButton Name="CloseBtn" Grid.Column="4" IconMargin="7" TextAreaRatio="0" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontWeight="Thin" FontSize="20" Canvas.Left="1126" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" IconSource="/图片资源/close.png"/>
        <control:DecoratedButton Name="MinBtn" Grid.Column="2" IconMargin="7" TextAreaRatio="0" Grid.Row="0" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IconSource="/图片资源/minimize.png" />
        <control:DecoratedButton Name="MaxBtn" Grid.Column="3" IconMargin="7" TextAreaRatio="0" Grid.Row="0" FontSize="20" Background="#FF383838" Foreground="LightGray" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="LightGray" PressedForeground="LightGray" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IconSource="/图片资源/maximize.png"/>
        <Grid Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <control:ExpandableBar BorderThickness="0.5" Margin="3" BarPlacement="Left" IsExpand="True" ExpandedText="&lt;&lt;" FrinkedText="数据列表" Grid.Column="0" ExpandedLength="2*" FrinkedLength="20" Grid.Row="1" Grid.RowSpan="2" BorderBrush="#FF707070">
                <control:ExpandableBar.ButtonTemplate>
                    <control:DecoratedButton HorizontalAlignment="Stretch" TextAreaRatio="1" FontSize="12" Background="Transparent" Foreground="LightGray" MoveInColor="#FF333333" PressedColor="#FF333333" MoveInForeground="LightGray" PressedForeground="LightGray" VerticalAlignment="Stretch"/>
                </control:ExpandableBar.ButtonTemplate>
                <control:ExpandableBar.ContentPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <control:ComboBox Grid.Row="0" Name="DataGroupName" Click="UpdateDataGroup" SelectionChanged="ShowDatas" Margin="2" FontSize="11" TextAreaRatio="0.9" IconMargin="7" ImagePlace="Right" Grid.ColumnSpan="2" Background="#FF424242" PressedColor="#FF3E3E3E" PressedForeground="White" MoveInForeground="White" Foreground="White" MoveInColor="#FF4D4D4D" IconSource="/图片资源/downArrow.png"/>
                        <基本控件:DataListViewer x:Name="DataList" Grid.Row="1" Grid.Column="0" ItemContextMenuSelected="DataListMenuEvents" Background="#FF1A1A1A">
                            <基本控件:DataListViewer.HeaderTemplate>
                                <control:ViewerTemplate Descriptions="名称" DataDisplayWidth="200" DataType="String" Editable="False"/>
                                <control:ViewerTemplate Descriptions="变量名" DataDisplayWidth="50" DataType="String" Editable="False"/>
                                <control:ViewerTemplate Descriptions="类型" DataDisplayWidth="100" DataType="String" Editable="False"/>
                                <control:ViewerTemplate Descriptions="数据量" DataDisplayWidth="100" DataType="String" Editable="False"/>
                            </基本控件:DataListViewer.HeaderTemplate>
                            <基本控件:DataListViewer.ContextTemplate>
                                <control:ContextMenu>
                                    <control:ContextMenu.Items>
                                        <control:DecoratedButton TextAreaRatio="1" Text="删除" FontSize="11" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                                    </control:ContextMenu.Items>
                                </control:ContextMenu>
                            </基本控件:DataListViewer.ContextTemplate>
                        </基本控件:DataListViewer>
                    </Grid>
                </control:ExpandableBar.ContentPanel>
            </control:ExpandableBar>
            <control:ExpandableBar BorderThickness="0.5" Margin="3" BarPlacement="Left" IsExpand="True" ExpandedText="&lt;&lt;" FrinkedText="数据处理方法" FrinkedLength="20" Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" BorderBrush="#FF707070">
                <control:ExpandableBar.ButtonTemplate>
                    <control:DecoratedButton HorizontalAlignment="Stretch" TextAreaRatio="1" FontSize="12" Background="Transparent" Foreground="LightGray" MoveInColor="#FF333333" PressedColor="#FF333333" MoveInForeground="LightGray" PressedForeground="LightGray" VerticalAlignment="Stretch"/>
                </control:ExpandableBar.ButtonTemplate>
                <control:ExpandableBar.ContentPanel>
                    <control:ListViewer Name="ProcessNames" Width="150" ItemSelected="ProcessNames_ItemSelected" ItemBarSelectedColor="#FF5BB3ED" ItemBarBackground="#FF2E2E2E">
                        <control:ListViewer.DataTemplate>
                            <control:ViewerTemplate Descriptions="处理方法" DataType="String" Editable="False" DataDisplayWidth="*"/>
                        </control:ListViewer.DataTemplate>
                        <control:ListViewer.TextBoxTemplate>
                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" BorderBrush="Transparent" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="White" FontSize="11" Background="Transparent" CaretBrush="White"/>
                        </control:ListViewer.TextBoxTemplate>
                        <control:ListViewer.HeaderLabelTemplate>
                            <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Foreground="White" FontSize="12"/>
                        </control:ListViewer.HeaderLabelTemplate>
                        <control:ListViewer.ItemContextMenu>
                            <control:ContextMenu>
                                <control:ContextMenu.Items>
                                    <control:DecoratedButton Text="显示算法描述" FontSize="12" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                                </control:ContextMenu.Items>
                            </control:ContextMenu>
                        </control:ListViewer.ItemContextMenu>
                    </control:ListViewer>
                </control:ExpandableBar.ContentPanel>
            </control:ExpandableBar>
            <Grid  Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Grid.ColumnSpan="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <TextBlock FontSize="11" Text="所有计算得到的数据均会保存在“计算数据”分组中" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                <Grid Name="ProcessPanel" Grid.Row="1">
                </Grid>
                <TextBlock Name="CalculateState" Grid.Row="2" HorizontalAlignment="Center" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <control:DecoratedButton Name="CalcBtn" Margin="2" Grid.Column="0" TextAreaRatio="1" Text="计算" FontSize="11" Click="Calculate" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                    <control:DecoratedButton Margin="2" Grid.Column="1" TextAreaRatio="1" Text="保存数据" FontSize="11" Click="SaveData" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                    <control:DecoratedButton Margin="2" Grid.Column="2" TextAreaRatio="1" Text="数据预览" FontSize="11" Click="DataViewing" Background="#FF383838" Foreground="White" MoveInColor="#FF424242" PressedColor="#FF39393A" MoveInForeground="White" PressedForeground="White"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
